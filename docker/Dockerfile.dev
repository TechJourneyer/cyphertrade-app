# Cyphertrade App - Development Dockerfile
# Node.js with Vite dev server for hot module replacement

FROM node:20-alpine

LABEL maintainer="Cyphertrade Team"
LABEL description="Cyphertrade React SPA - Development"

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy source code (will be overridden by volume mount)
COPY . .

# Expose Vite dev server port
EXPOSE 3000

# Environment variables
ENV HOST=0.0.0.0
ENV PORT=3000

# Start Vite development server
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
