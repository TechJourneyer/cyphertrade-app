# Cyphertrade App - Development Dockerfile
# Node.js with Next.js dev server for hot module replacement

FROM node:20-alpine

LABEL maintainer="Cyphertrade Team"
LABEL description="Cyphertrade Next.js App - Development"

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy source code (will be overridden by volume mount)
COPY . .

# Expose Next.js dev server port
EXPOSE 3000

# Environment variables
ENV HOST=0.0.0.0
ENV PORT=3000
ENV NEXT_TELEMETRY_DISABLED=1

# Start Next.js development server
CMD ["npm", "run", "dev"]
