# ===========================================
# Cyphertrade App - Docker Environment Configuration
# ===========================================
# Copy this file to .env.docker and customize

# Application Port
WEB_PORT=3000

# API Configuration (connects to cyphertrade-api)
VITE_API_URL=http://localhost:8000/api/v1

# WebSocket Configuration
VITE_WS_URL=ws://localhost:8082
